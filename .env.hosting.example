# Copiar a .env.hosting para docker-compose.prod.yml (no versionar .env.hosting)
# Ver docs/DEPLOY_MAC_MINI.md
#
# Quick tunnel: las URLs cambian cada vez que reinicias cloudflared.
# Actualiza este archivo y reinicia: docker compose -p fittrack -f docker-compose.prod.yml up -d --force-recreate fittrack-frontend fittrack-backend
#
# Dominio fijo (fase 2):
#   NEXT_PUBLIC_API_BASE_URL=https://api.tudominio.com

# --- Smoke test local (sin tunnel) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# --- Quick tunnel / dominio público (descomentar y sustituir) ---
# NEXT_PUBLIC_API_BASE_URL=https://xxxxxxxx.trycloudflare.com

# Modo API completo (no cambiar en hosting)
NEXT_PUBLIC_AUTH_SOURCE=api
NEXT_PUBLIC_DATA_SOURCE=api
NEXT_PUBLIC_DATA_SOURCE_METRICS=api
NEXT_PUBLIC_DATA_SOURCE_ROUTINES=api
NEXT_PUBLIC_DATA_SOURCE_USERS=api
NEXT_PUBLIC_DATA_SOURCE_NUTRITION=api
NEXT_PUBLIC_DATA_SOURCE_MEMBERSHIPS=api

# Ollama en el host (Mac Mini / Windows con Docker Desktop)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Redis para rate limit distribuido en rutas Titan (compose prod)
TITAN_RATELIMIT_REDIS_URL=redis://fittrack-redis:6379

# Opcional: si usas sustitución ${CORS_ORIGINS} en compose desde la raíz del repo
# (también deben coincidir en backend/.env)
# CORS_ORIGINS=https://xxxxxxxx.trycloudflare.com
# FRONTEND_URL=https://yyyyyyyy.trycloudflare.com
