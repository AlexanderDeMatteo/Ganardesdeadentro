# Copiar a backend/.env para docker-compose.prod.yml (no versionar backend/.env)
# Ver docs/DEPLOY_MAC_MINI.md
#
# Generar JWT seguro (obligatorio en producción):
#   openssl rand -hex 32
# Nunca uses el valor de desarrollo ni lo subas a Git.

# ==================== AMBIENTE ====================
ENVIRONMENT=production
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ==================== BASE DE DATOS ====================
DATABASE_URL=sqlite:////data/fitness_platform.db
SQL_ECHO=False

# ==================== JWT ====================
JWT_SECRET_KEY=REEMPLAZAR_CON_openssl_rand_hex_32
JWT_EXPIRATION_HOURS=24
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True

# ==================== RATE LIMITING ====================
AUTH_RATE_LIMIT=10 per minute
RATELIMIT_ENABLED=True
# En compose prod se sobrescribe a redis://fittrack-redis:6379
RATELIMIT_STORAGE_URI=redis://fittrack-redis:6379

# ==================== CORS / FRONTEND ====================
# Smoke test local:
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Quick tunnel (sustituir por URL pública del frontend, sin barra final):
# CORS_ORIGINS=https://yyyyyyyy.trycloudflare.com
# FRONTEND_URL=https://yyyyyyyy.trycloudflare.com

# Dominio fijo (fase 2):
# CORS_ORIGINS=https://app.tudominio.com
# FRONTEND_URL=https://app.tudominio.com

# ==================== ExerciseDB API ====================
EXERCISEDB_API_URL=https://oss.exercisedb.dev
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=
EXERCISEDB_SSL_VERIFY=true

# ==================== LOGGING ====================
LOG_LEVEL=INFO

# ==================== EMAIL / INVITACIONES ====================
RESEND_API_KEY=
EMAIL_FROM=FitTrack <onboarding@tudominio.com>
INVITATION_EXPIRY_HOURS=72

# ==================== UPLOADS (volumen Docker /data) ====================
EXERCISE_MEDIA_UPLOAD_DIR=/data/exercise_media
EXERCISE_MEDIA_MAX_BYTES=10485760
EXERCISE_MEDIA_RAW_MAX_BYTES=52428800
EXERCISE_MEDIA_ALLOWED_MIME=image/gif,video/mp4,image/webp
EXERCISE_MEDIA_TRANSCODE_ENABLED=true
EXERCISE_MEDIA_MAX_DURATION_SECONDS=60
EXERCISE_MEDIA_VIDEO_MAX_WIDTH=1280
EXERCISE_MEDIA_VIDEO_CRF=26

PAYMENT_RECEIPT_UPLOAD_DIR=/data/payment_receipts
PAYMENT_RECEIPT_MAX_BYTES=5242880
PAYMENT_RECEIPT_ALLOWED_MIME=image/jpeg,image/png,image/gif,application/pdf

SESSION_EXECUTION_MEDIA_UPLOAD_DIR=/data/session_execution_media
SESSION_EXECUTION_MEDIA_MAX_BYTES=52428800

# Sin seeds demo en producción
SEED_DEMO_TRAINERS=false
