# ==================== AMBIENTE ====================
ENVIRONMENT=development
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Solo aplica cuando ENVIRONMENT=production (entrypoint con Gunicorn)
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120

# ==================== BASE DE DATOS ====================
# SQLite (desarrollo - por defecto)
DATABASE_URL=sqlite:///fitness_platform.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql://user:password@localhost:5432/personal_trainers
SQL_ECHO=False

# ==================== JWT ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_EXPIRATION_HOURS=24
JWT_COOKIE_SECURE=False
JWT_COOKIE_CSRF_PROTECT=True

# ==================== RATE LIMITING ====================
# Límite global por IP para toda la API Flask
GLOBAL_RATE_LIMIT=120 per minute
# Límite para login, register y change-password
AUTH_RATE_LIMIT=10 per minute
# Límite para endpoints públicos de ejercicios
PUBLIC_API_RATE_LIMIT=60 per minute
# Límite para uploads multipart en endpoints sensibles
UPLOAD_RATE_LIMIT=10 per minute
RATELIMIT_ENABLED=True
# memory:// para desarrollo; redis://localhost:6379 en producción multi-proceso
RATELIMIT_STORAGE_URI=memory://

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# ==================== ExerciseDB API (gratuita con GIF) ====================
# Por defecto usa la API OSS sin clave: https://oss.exercisedb.dev
EXERCISEDB_API_URL=https://oss.exercisedb.dev
# Solo si usas RapidAPI (de pago): https://docs.ascendapi.com/quickstart/overview.md
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=
# En Docker Desktop (Windows) a veces hace falta false; en producción debe ser true
EXERCISEDB_SSL_VERIFY=true

# ==================== LOGGING ====================
LOG_LEVEL=INFO

# ==================== EMAIL / INVITACIONES ====================
# Resend: https://resend.com — sin clave, el backend registra envío simulado en logs
# Verifica tu dominio en https://resend.com/domains (SPF/DKIM). No uses @resend.dev fuera de pruebas.
RESEND_API_KEY=
EMAIL_FROM=Be a Gainer <invitaciones@beagainer.life>
EMAIL_REPLY_TO=soporte@beagainer.life
FRONTEND_URL=http://localhost:3000
INVITATION_EXPIRY_HOURS=72

# ==================== EJERCICIOS CUSTOM / MEDIA ====================
EXERCISE_MEDIA_UPLOAD_DIR=/data/exercise_media
EXERCISE_MEDIA_MAX_BYTES=10485760
EXERCISE_MEDIA_RAW_MAX_BYTES=52428800
EXERCISE_MEDIA_ALLOWED_MIME=image/gif,video/mp4,image/webp
EXERCISE_MEDIA_TRANSCODE_ENABLED=true
EXERCISE_MEDIA_MAX_DURATION_SECONDS=60
EXERCISE_MEDIA_VIDEO_MAX_WIDTH=1280
EXERCISE_MEDIA_VIDEO_CRF=26

# Entrenadores demo activos al arrancar (solo development; desactivar con false)
SEED_DEMO_TRAINERS=true

# Dataset QA manual (1 admin + 10 trainers + 50 atletas @fittrack.qa):
# python scripts/seed_qa_dataset.py
# Ver docs/QA_GUIDE.md
