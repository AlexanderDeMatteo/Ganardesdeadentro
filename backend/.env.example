# ==================== AMBIENTE ====================
ENVIRONMENT=development
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ==================== BASE DE DATOS ====================
# SQLite (desarrollo - por defecto)
DATABASE_URL=sqlite:///fitness_platform.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql://user:password@localhost:5432/personal_trainers
SQL_ECHO=False

# ==================== JWT ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_EXPIRATION_HOURS=24
JWT_COOKIE_SECURE=False
JWT_COOKIE_CSRF_PROTECT=True

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# ==================== ExerciseDB API ====================
# Obtén tu API key en: https://rapidapi.com/justin-WFnsXH_haHLw/api/exercisedb
EXERCISEDB_API_KEY=your-rapidapi-key-here
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com

# ==================== LOGGING ====================
LOG_LEVEL=INFO
