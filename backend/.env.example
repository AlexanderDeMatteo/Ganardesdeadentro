# ==================== AMBIENTE ====================
ENVIRONMENT=development
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ==================== BASE DE DATOS ====================
# SQLite (desarrollo - por defecto)
DATABASE_URL=sqlite:///fitness_platform.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql://user:password@localhost:5432/personal_trainers
SQL_ECHO=False

# ==================== JWT ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_EXPIRATION_HOURS=24
JWT_COOKIE_SECURE=False
JWT_COOKIE_CSRF_PROTECT=True

# ==================== RATE LIMITING ====================
# Límite para login, register y change-password
AUTH_RATE_LIMIT=10 per minute
RATELIMIT_ENABLED=True
# memory:// para desarrollo; redis://localhost:6379 en producción multi-proceso
RATELIMIT_STORAGE_URI=memory://

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# ==================== ExerciseDB API ====================
# Obtén tu API key en: https://rapidapi.com/justin-WFnsXH_haHLw/api/exercisedb
EXERCISEDB_API_KEY=your-rapidapi-key-here
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com

# ==================== LOGGING ====================
LOG_LEVEL=INFO

# ==================== EMAIL / INVITACIONES ====================
# Resend: https://resend.com — sin clave, el backend registra envío simulado en logs
RESEND_API_KEY=
EMAIL_FROM=FitTrack <onboarding@tudominio.com>
FRONTEND_URL=http://localhost:3000
INVITATION_EXPIRY_HOURS=72

# Entrenadores demo activos al arrancar (solo development; desactivar con false)
SEED_DEMO_TRAINERS=true

# Dataset QA manual (1 admin + 10 trainers + 50 atletas @fittrack.qa):
# python scripts/seed_qa_dataset.py
# Ver docs/QA_GUIDE.md
