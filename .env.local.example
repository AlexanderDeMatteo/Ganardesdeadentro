# Copia a .env.local (no versionar .env.local)

# --- Backend Flask (integración opcional) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Auth: local = usuarios mock en cliente; api = JWT contra Flask
NEXT_PUBLIC_AUTH_SOURCE=local

# Datos generales: local = localStorage; api = backend Flask
NEXT_PUBLIC_DATA_SOURCE=local

# Override por dominio (piloto incremental): api | local
# Con AUTH_SOURCE=api, athleteId debe coincidir con user.id del JWT
NEXT_PUBLIC_DATA_SOURCE_METRICS=local
NEXT_PUBLIC_DATA_SOURCE_ROUTINES=local
NEXT_PUBLIC_DATA_SOURCE_USERS=local
NEXT_PUBLIC_DATA_SOURCE_NUTRITION=local
NEXT_PUBLIC_DATA_SOURCE_MEMBERSHIPS=local

# --- Ollama (coach Titan) — solo servidor Next (no usar NEXT_PUBLIC_*) ---
OLLAMA_BASE_URL=http://localhost:11434

# Rate limit Titan por userId (memoria en proceso; prod distribuido → Fase 7 + ioredis)
# TITAN_RATELIMIT_REDIS_URL=redis://localhost:6379
# TITAN_RATELIMIT_MAX_REQUESTS=30
# TITAN_RATELIMIT_WINDOW_MS=60000

# --- Perfil API completo (Fase 5) — copiar a .env.local para modo api ---
# NEXT_PUBLIC_AUTH_SOURCE=api
# NEXT_PUBLIC_DATA_SOURCE=api
# NEXT_PUBLIC_DATA_SOURCE_METRICS=api
# NEXT_PUBLIC_DATA_SOURCE_ROUTINES=api
# NEXT_PUBLIC_DATA_SOURCE_USERS=api
# NEXT_PUBLIC_DATA_SOURCE_NUTRITION=api
# NEXT_PUBLIC_DATA_SOURCE_MEMBERSHIPS=api
